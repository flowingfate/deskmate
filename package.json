{
  "name": "deskmate",
  "version": "0.0.1",
  "description": "Deskmate AI Studio",
  "author": "flowingfate",
  "license": "Apache-2.0",
  "homepage": "./",
  "private": true,
  "main": "out/main/bootstrap.js",
  "scripts": {
    "electron": "electron . --disable-gpu-sandbox --no-sandbox",
    "check:impact": "node scripts/check-impact.js",
    "test": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run --silent",
    "test:coverage": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run --coverage --silent",
    "typecheck": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && tsc -p tsconfig.renderer.json && node scripts/check-mixed-imports.js --quiet",
    "dev": "cross-env ELECTRON_ENTRY=out/main/bootstrap.js electron-vite dev -w",
    "build": "electron-vite build",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "ladle:preview": "ladle preview",
    "start": "npm run build && electron out/main/bootstrap.js --disable-gpu-sandbox --no-sandbox",
    "pack": "bun scripts/vite/pack.ts --dir --skip-build",
    "dist": "bun scripts/vite/pack.ts",
    "dist:mac:arm64": "bun scripts/vite/pack.ts --mac --arm64",
    "dist:win:x64": "bun scripts/vite/pack.ts --win --x64",
    "dist:publish": "bun scripts/vite/pack.ts --publish always",
    "diagnose": "./scripts/diagnose-sandbox.sh",
    "debug:update": "node scripts/debug-update-check.js",
    "debug:update-verbose": "DEBUG=* node scripts/debug-update-check.js",
    "prepare:release": "node scripts/prepare-release.js",
    "prepare:release:patch": "node scripts/prepare-release.js patch",
    "prepare:release:minor": "node scripts/prepare-release.js minor",
    "prepare:release:major": "node scripts/prepare-release.js major",
    "rebuild": "node scripts/rebuild-native.js",
    "postinstall": "node scripts/rebuild-native.js && node scripts/setup-ai-docs.js",
    "generate-mac-icons-with-padding": "node scripts/generate-mac-icons-with-padding.js",
    "build:visual-updater": "node scripts/build-visual-updater.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "pretest:e2e": "npm run build"
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.5",
    "@earendil-works/pi-ai": "^0.79.10",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@vscode/ripgrep": "^1.15.14",
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^5.5.0",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "micromatch": "^4.0.8",
    "node-cron": "^4.2.1",
    "node-html-parser": "^7.0.1",
    "node-screenshots": "^0.2.8",
    "node-stream-zip": "^1.15.0",
    "pdfreader": "^3.0.7",
    "pino": "10.3.1",
    "pino-abstract-transport": "3.0.0",
    "pino-pretty": "13.1.3",
    "playwright-core": "^1.58.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@electron/rebuild": "^4.0.3",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.58.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-virtual": "3.13.26",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.12",
    "@types/ejs": "^3.1.5",
    "@types/lodash": "^4.17.23",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.19.9",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/stylis": "^4.2.7",
    "@vanilla-extract/css": "^1.20.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "buffer": "^6.0.3",
    "caniuse-lite": "^1.0.30001757",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cross-env": "^7.0.3",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^6.11.0",
    "ejs": "^3.1.10",
    "electron": "^41.7.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^6.0.0-beta.1",
    "events": "^3.3.0",
    "immer": "^11.1.3",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.525.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "node-loader": "^2.1.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "playwright": "^1.58.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.4",
    "postcss-selector-parser": "^7.1.1",
    "process": "^0.11.10",
    "purgecss": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-refresh": "^0.18.0",
    "react-router-dom": "^6.30.3",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "serve": "^14.2.5",
    "stream-browserify": "^3.0.0",
    "style-loader": "^3.3.4",
    "stylis": "^4.3.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.2.2",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "util": "^0.12.5",
    "vite": "^8.1.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "lodash-es": "^4.17.23"
  }
}
